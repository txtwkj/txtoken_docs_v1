{
  "openapi": "3.1.0",
  "info": {
    "title": "获取令牌使用情况",
    "version": "1.0.0",
    "description": "🔑 需要令牌认证（TokenAuth）"
  },
  "servers": [
    {
      "url": "https://api.txtoken.cn"
    }
  ],
  "tags": [
    {
      "name": "令牌管理"
    }
  ],
  "components": {
